# Copy this file to .env in the repository root before running docker compose.

APP_PORT=8080
APP_VERSION=1.0.0

DB_NAME=guts_db
DB_USER=guts_app
DB_PASSWORD=change_me_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password

JWT_SECRET=change_me_to_a_very_long_random_secret
JWT_EXPIRES_IN=8h

# First deployment on a fresh DB: keep true so backend can create base tables.
# After first successful startup, switch to false and redeploy to use migration-first startup.
DB_BOOTSTRAP_SYNC=true

# Keep false in production to prevent auto-seeding default users.
SEED_DEFAULT_USERS=false
SEED_ADMIN_EMAIL=admin@guts.local
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
SEED_STAFF_EMAIL=staff@guts.local
SEED_STAFF_PASSWORD=ChangeMe!Staff123

# Must match the exact URL users open in browser.
CORS_ALLOWED_ORIGINS=http://localhost:8080

LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=26
MYSQL_DUMP_COMMAND=mariadb-dump
MYSQL_DUMP_EXTRA_ARGS=--skip-ssl --no-tablespaces

LOG_LEVEL=info
REQUEST_LOG_INCLUDE_HEALTH=false

# Optional: webhook endpoint for backup success/failure notifications
BACKUP_ALERT_WEBHOOK_URL=

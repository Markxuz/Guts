DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost

# Optional app settings
PORT=5000
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h
DB_SYNC=false
NODE_ENV=production

# Restrict browser access origins in production (comma-separated)
# Example: CORS_ALLOWED_ORIGINS=http://guts.company.local,https://guts.tailnet.ts.net
CORS_ALLOWED_ORIGINS=

# Login brute-force protection
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Default account seeding (recommended false outside local development)
SEED_DEFAULT_USERS=false
SEED_ADMIN_EMAIL=admin@guts.local
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
SEED_STAFF_EMAIL=staff@guts.local
SEED_STAFF_PASSWORD=ChangeMe!Staff123

# Backup automation config
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=26
BACKUP_RESTORE_TEST_DB_PREFIX=guts_restore_test
BACKUP_RESTORE_TEST_CLEANUP=true

# Optional outgoing webhook for backup success/failure notifications
BACKUP_ALERT_WEBHOOK_URL=

# Logging and request tracing
LOG_LEVEL=info
REQUEST_LOG_INCLUDE_HEALTH=false
APP_VERSION=1.0.0

# Scheduled report email delivery
REPORT_EMAIL_WORKER_ENABLED=true
REPORT_EMAIL_POLL_INTERVAL_MS=60000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
